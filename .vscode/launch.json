{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch SmartShop WebAPI",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-webapi",
            "program": "${workspaceFolder}/src/SmartShop.WebAPI/bin/Debug/net8.0/SmartShop.WebAPI.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/SmartShop.WebAPI",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}
